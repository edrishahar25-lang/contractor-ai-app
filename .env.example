# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required for AI blueprint analysis
ANTHROPIC_API_KEY=sk-ant-...

# Server port (Railway/Render set this automatically)
PORT=3001

# Set to 'production' when deploying
NODE_ENV=development

# Optional: custom SQLite path (defaults to ./data/contractor.db)
# DB_PATH=/data/contractor.db

# Optional: restrict CORS to your frontend URL in production
# FRONTEND_URL=https://your-app.railway.app
